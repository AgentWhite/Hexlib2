{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "HexLib/HexLib.csproj",
            "ASL/ASL.csproj",
            "ASLInputTool/ASLInputTool.csproj"
          ],
          "src": "../"
        }
      ],
      "dest": "api",
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [ "api/**.yml", "api/index.md" ]
      },
      {
        "files": [ "articles/**.md", "articles/**/toc.yml", "toc.yml", "*.md" ]
      }
    ],
    "resource": [
      {
        "files": [ "images/**" ]
      }
    ],
    "output": "_site",
    "template": [ "default", "modern" ],
    "globalMetadata": {
      "_appName": "HexLib / ASL Documentation",
      "_appTitle": "HexLib & ASL",
      "_appFooter": "HexLib · Advanced Squad Leader Toolset",
      "_enableSearch": true,
      "_disableContribution": true
    }
  }
}
