<Application x:Class="ASLInputTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ASLInputTool"
             xmlns:vm="clr-namespace:ASLInputTool.ViewModels"
             xmlns:v="clr-namespace:ASLInputTool.Views"
             xmlns:c="clr-namespace:ASLInputTool.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <c:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
            <DataTemplate DataType="{x:Type vm:CountersViewModel}">
                <v:CountersView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ScenariosViewModel}">
                <v:ScenariosView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
