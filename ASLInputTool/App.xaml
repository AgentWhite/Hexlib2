<Application x:Class="ASLInputTool.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ASLInputTool"
             xmlns:vm="clr-namespace:ASLInputTool.ViewModels"
             xmlns:v="clr-namespace:ASLInputTool.Views"
             xmlns:c="clr-namespace:ASLInputTool.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Brushes.xaml"/>
                <ResourceDictionary Source="Themes/UnitStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis" />
            <c:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
            <c:NullToVisibilityConverter x:Key="NullToVis" />
            <c:CounterStatsConverter x:Key="CounterStats" />
            <c:InverseBooleanConverter x:Key="InverseBool" />
            <c:ImageSourceConverter x:Key="ImageSource" />
            <c:SvgToImageSourceConverter x:Key="SvgToImage" />
            
            <Style TargetType="DataGridCell">
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="{x:Type DataGridCell}">
                            <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                <ContentPresenter VerticalAlignment="Center" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="DataGrid">
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Style.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                    </Style>
                    <Style TargetType="CheckBox">
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="HorizontalAlignment" Value="Center" />
                    </Style>
                </Style.Resources>
            </Style>

            <Style TargetType="TextBox">
                <Setter Property="Padding" Value="5"/>
                <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Grid>
                                <Border x:Name="border" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Background="{TemplateBinding Background}" SnapsToDevicePixels="True">
                                    <ScrollViewer x:Name="PART_ContentHost" Focusable="false" HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Hidden" VerticalAlignment="Stretch"/>
                                </Border>
                                <TextBlock x:Name="hintText" Text="{TemplateBinding Tag}" Margin="7,5,0,0" Foreground="Gray" IsHitTestVisible="False" Visibility="Collapsed" VerticalAlignment="Top" FontStyle="Italic"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Text" Value="">
                                    <Setter TargetName="hintText" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsKeyboardFocused" Value="true">
                                    <Setter TargetName="hintText" Property="Visibility" Value="Collapsed"/>
                                </Trigger>
                                <Trigger Property="Validation.HasError" Value="true">
                                    <Setter Property="ToolTip" Value="{Binding RelativeSource={RelativeSource Self}, Path=(Validation.Errors)[0].ErrorContent}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource ValidationErrorBrush}"/>
                                    <Setter Property="BorderThickness" Value="2"/>
                                    <Setter Property="Background" Value="{StaticResource ValidationBackgroundBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="{StaticResource DisabledBackgroundBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource DisabledTextBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <DataTemplate DataType="{x:Type vm:LeadersViewModel}">
                <v:LeadersView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:HeroesViewModel}">
                <v:HeroesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:SquadsViewModel}">
                <v:SquadsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:EquipmentViewModel}">
                <v:EquipmentView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:OrdnanceViewModel}">
                <TextBlock Text="Ordnance View Coming Soon" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="Gray"/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:VehiclesViewModel}">
                <TextBlock Text="Vehicles View Coming Soon" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="Gray"/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:NationalCountersViewModel}">
                <TextBlock Text="National Counters View Coming Soon" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="Gray"/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:MiscCountersViewModel}">
                <TextBlock Text="Misc Counters View Coming Soon" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="20" FontWeight="Bold" Foreground="Gray"/>
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ScenariosViewModel}">
                <v:ScenariosView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:ModulesViewModel}">
                <v:ModulesView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:BoardsViewModel}">
                <v:AslBoardsView />
            </DataTemplate>
            <DataTemplate DataType="{x:Type vm:BoardEditorViewModel}">
                <v:BoardEditorView />
            </DataTemplate>
        </ResourceDictionary>
    </Application.Resources>
</Application>
