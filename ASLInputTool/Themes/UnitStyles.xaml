<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:c="clr-namespace:ASLInputTool.Converters">

    <!-- Filter Bar Styles -->
    <Style x:Key="FilterStackPanelStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Margin" Value="0,0,0,10"/>
    </Style>

    <Style x:Key="FilterLabelStyle" TargetType="Label">
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Foreground" Value="Gray"/>
    </Style>

    <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Width" Value="120"/>
        <Setter Property="Margin" Value="5,0,0,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="FilterClearButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="5,0,0,0"/>
        <Setter Property="Padding" Value="10,2"/>
    </Style>

    <!-- DataGrid Unit View Style -->
    <Style x:Key="UnitDataGridStyle" TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="AutoGenerateColumns" Value="False"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
        <Setter Property="BorderThickness" Value="2"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource ControlBorderBrush}"/>
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource ControlBorderBrush}"/>
    </Style>

    <!-- Header Action Button Styles -->
    <Style x:Key="HeaderAddButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="20,0,0,0"/>
        <Setter Property="Padding" Value="15,5"/>
        <Setter Property="Background" Value="{StaticResource ControlBorderBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>

    <Style x:Key="HeaderDeleteButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="10,0,0,0"/>
        <Setter Property="Padding" Value="15,5"/>
        <Setter Property="Background" Value="{StaticResource ValidationErrorBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="FontWeight" Value="Bold"/>
    </Style>
    
    <Style x:Key="HeaderBackButtonStyle" TargetType="Button">
        <Setter Property="Margin" Value="20,0,0,0"/>
        <Setter Property="Padding" Value="15,5"/>
    </Style>

</ResourceDictionary>
