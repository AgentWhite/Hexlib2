<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Core Theme Colors -->
    <Color x:Key="PrimaryBackground">LightSkyBlue</Color>
    <Color x:Key="SecondaryBackground">CornflowerBlue</Color>
    <Color x:Key="AccentColor">Green</Color>
    <Color x:Key="ValidationBackground">#FFF0F0</Color>
    <Color x:Key="ValidationError">Red</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="{StaticResource PrimaryBackground}"/>
    <SolidColorBrush x:Key="ControlBorderBrush" Color="{StaticResource SecondaryBackground}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="ValidationBackgroundBrush" Color="{StaticResource ValidationBackground}"/>
    <SolidColorBrush x:Key="ValidationErrorBrush" Color="{StaticResource ValidationError}"/>
    <SolidColorBrush x:Key="DisabledBackgroundBrush" Color="#DCDCDC"/>
    <SolidColorBrush x:Key="DisabledTextBrush" Color="Gray"/>
    
</ResourceDictionary>
