<Window x:Class="ASLInputTool.Views.NameInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="New Formation" Height="200" Width="380"
        SizeToContent="Height" MinHeight="180"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Prompt}" FontWeight="SemiBold" Margin="0,0,0,15"/>
        
        <TextBox Grid.Row="1" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" 
                 VerticalContentAlignment="Center" Padding="8" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="OK" Command="{Binding OkCommand}" Width="80" Padding="5" Margin="0,0,10,0" IsDefault="True"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Width="80" Padding="5" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
