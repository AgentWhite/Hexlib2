<UserControl x:Class="ASLInputTool.Views.HeroesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:ASLInputTool.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance vm:HeroesViewModel}"
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource ControlBorderBrush}"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="20" Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,20">
            <TextBlock Text="Heroes" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Add Hero" Command="{Binding AddCommand}" 
                    Visibility="{Binding IsAdding, Converter={StaticResource InverseBoolToVis}}"
                    Margin="20,0,0,0" Padding="15,5" Background="{StaticResource ControlBorderBrush}" Foreground="White" FontWeight="Bold"/>
            <Button Content="Back to List" Command="{Binding CancelCommand}" 
                    Visibility="{Binding IsAdding, Converter={StaticResource BoolToVis}}"
                    Margin="20,0,0,0" Padding="15,5"/>
        </StackPanel>

        <!-- List View -->
        <Grid Grid.Row="1" Visibility="{Binding IsAdding, Converter={StaticResource InverseBoolToVis}}">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True" Background="{StaticResource WindowBackgroundBrush}">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" 
                                  Command="{Binding EditCommand}" 
                                  CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Nationality" Binding="{Binding Nationality}" Width="120" />
                    <DataGridTextColumn Header="Stats" Binding="{Binding ., Converter={StaticResource CounterStats}}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Form View -->
        <ScrollViewer Grid.Row="1" Padding="10" Visibility="{Binding IsAdding, Converter={StaticResource BoolToVis}}" Background="{StaticResource WindowBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Image Frame -->
                <Button Grid.Column="0" Command="{Binding PickImageCommand}" 
                        Width="120" Height="120" Margin="0,0,20,20" VerticalAlignment="Top">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="2" Background="White">
                                <Grid>
                                    <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                                    <TextBlock Text="Click to add image" Visibility="{Binding ImagePath, Converter={StaticResource NullToVis}}" 
                                               VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" 
                                               Foreground="Gray" TextWrapping="Wrap" Padding="10"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <StackPanel Grid.Column="1">
                    <Label Content="Hero Name:" FontWeight="SemiBold"/>
                    <TextBox Margin="0,0,0,10" Tag="e.g., Sgt. Rock" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                    <Label Content="Nationality:" FontWeight="SemiBold"/>
                    <ComboBox Margin="0,0,0,10" Padding="5"
                              ItemsSource="{Binding Nationalities}"
                              SelectedItem="{Binding SelectedNationality}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <Label Content="Firepower:" FontWeight="SemiBold"/>
                            <TextBox Width="50" HorizontalAlignment="Left" Tag="1" Text="{Binding Firepower, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,20,0">
                            <Label Content="Range:" FontWeight="SemiBold"/>
                            <TextBox Width="50" HorizontalAlignment="Left" Tag="4" Text="{Binding Range, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <Label Content="Morale:" FontWeight="SemiBold"/>
                            <TextBox Width="50" HorizontalAlignment="Left" Tag="9" Text="{Binding Morale, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="Save Hero" Command="{Binding SaveCommand}" Margin="0,20,0,0" Padding="20,10" HorizontalAlignment="Right" Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
