<UserControl x:Class="ASLInputTool.Views.CountersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:asl="clr-namespace:ASL;assembly=ASL"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource ControlBorderBrush}"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="20" Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,20">
            <TextBlock Text="Counters" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Add Counter" Command="{Binding AddCommand}" 
                    Visibility="{Binding IsAdding, Converter={StaticResource InverseBoolToVis}}"
                    Margin="20,0,0,0" Padding="15,5" Background="{StaticResource ControlBorderBrush}" Foreground="White" FontWeight="Bold"/>
            <Button Content="Back to List" Command="{Binding CancelCommand}" 
                    Visibility="{Binding IsAdding, Converter={StaticResource BoolToVis}}"
                    Margin="20,0,0,0" Padding="15,5"/>
        </StackPanel>

        <!-- List View -->
        <Grid Grid.Row="1" Visibility="{Binding IsAdding, Converter={StaticResource InverseBoolToVis}}">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="True" Background="{StaticResource WindowBackgroundBrush}">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" 
                                  Command="{Binding EditCommand}" 
                                  CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nationality" Binding="{Binding Nationality}" Width="120" />
                    <DataGridTextColumn Header="Unit class" Binding="{Binding AslClass}" Width="120" />
                    <DataGridTextColumn Header="Stats" Binding="{Binding Stats}" Width="*" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Form View (The original entry form) -->
        <TabControl Grid.Row="1" Visibility="{Binding IsAdding, Converter={StaticResource BoolToVis}}" Background="{StaticResource WindowBackgroundBrush}">
            <TabItem Header="Single Man (SMC)">
                <ScrollViewer Padding="10" Background="{StaticResource WindowBackgroundBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Image Frame -->
                        <Button Grid.Row="0" Grid.Column="0" Command="{Binding PickImageCommand}" 
                                Width="120" Height="120" Margin="0,0,20,20" VerticalAlignment="Top">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="2" Background="White">
                                        <Grid>
                                            <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                                            <TextBlock Text="Click to add image" Visibility="{Binding ImagePath, Converter={StaticResource NullToVis}}" 
                                                       VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" 
                                                       Foreground="Gray" TextWrapping="Wrap" Padding="10"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="2">
                            <Label Content="Counter Name:" FontWeight="SemiBold"/>
                            <TextBox Margin="0,0,0,10" Tag="e.g., Sgt. Steiner" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                            <Label Content="Nationality:" FontWeight="SemiBold"/>
                            <ComboBox Margin="0,0,0,10" Padding="5"
                                      ItemsSource="{Binding Nationalities}"
                                      SelectedItem="{Binding SelectedNationality}"/>

                            <Label Content="Morale:" FontWeight="SemiBold"/>
                            <TextBox Margin="0,0,0,10" Width="50" HorizontalAlignment="Left" Tag="7" Text="{Binding Morale, UpdateSourceTrigger=PropertyChanged}"/>

                            <GroupBox Header="Type Specific" Margin="0,10,0,0">
                                <StackPanel Margin="10">
                                    <RadioButton Content="Leader" IsChecked="{Binding IsLeader}" Margin="0,0,0,5"/>
                                    <StackPanel Margin="20,0,0,10" IsEnabled="{Binding IsLeader}">
                                        <Label Content="Leadership Modifier:"/>
                                        <TextBox Width="50" HorizontalAlignment="Left" Tag="0" Text="{Binding Leadership, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <RadioButton Content="Hero" IsChecked="{Binding IsLeader, Converter={StaticResource InverseBool}}" Margin="0,0,0,5"/>
                                    <StackPanel Margin="20,0,0,10" IsEnabled="{Binding IsLeader, Converter={StaticResource InverseBool}}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                                <Label Content="Firepower:"/>
                                                <TextBox Width="50" HorizontalAlignment="Left" Tag="1" Text="{Binding Firepower, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <Label Content="Range:"/>
                                                <TextBox Width="50" HorizontalAlignment="Left" Tag="4" Text="{Binding Range, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </GroupBox>
                            <Button Content="Save Counter" Command="{Binding SaveCommand}" CommandParameter="SMC" Margin="0,20,0,0" Padding="20,10" HorizontalAlignment="Right" Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
            
            <TabItem Header="Multi Man (MMC)">
                <ScrollViewer Padding="10" Background="{StaticResource WindowBackgroundBrush}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <!-- Image Frame -->
                        <Button Grid.Row="0" Grid.Column="0" Command="{Binding PickImageCommand}" 
                                Width="120" Height="120" Margin="0,0,20,20" VerticalAlignment="Top">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="2" Background="White">
                                        <Grid>
                                            <Image Source="{Binding ImagePath}" Stretch="UniformToFill"/>
                                            <TextBlock Text="Click to add image" Visibility="{Binding ImagePath, Converter={StaticResource NullToVis}}" 
                                                       VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" 
                                                       Foreground="Gray" TextWrapping="Wrap" Padding="10"/>
                                        </Grid>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="2">
                            <Label Content="Counter Name / Unit Identity:" FontWeight="SemiBold"/>
                            <TextBox Margin="0,0,0,10" Tag="e.g., 1st Squad" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <Label Content="Nationality:" FontWeight="SemiBold"/>
                                    <ComboBox Padding="5"
                                              ItemsSource="{Binding Nationalities}"
                                              SelectedItem="{Binding SelectedNationality}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <Label Content="Class:" FontWeight="SemiBold"/>
                                    <ComboBox Padding="5"
                                              ItemsSource="{Binding UnitClasses}"
                                              SelectedItem="{Binding SelectedClass}"/>
                                </StackPanel>
                            </Grid>

                            <Grid Margin="0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                    <Label Content="Firepower:"/>
                                    <TextBox Width="50" HorizontalAlignment="Left" Tag="4" Text="{Binding Firepower, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,20,0">
                                    <Label Content="Range:"/>
                                    <TextBox Width="50" HorizontalAlignment="Left" Tag="6" Text="{Binding Range, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <Label Content="Morale:"/>
                                    <TextBox Width="50" HorizontalAlignment="Left" Tag="7" Text="{Binding Morale, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>
                            </Grid>

                            <CheckBox Content="Has Assault Fire" IsChecked="{Binding HasAssaultFire}" Margin="0,5"/>
                            <CheckBox Content="Has Spraying Fire" IsChecked="{Binding HasSprayingFire}" Margin="0,5"/>
                            <CheckBox Content="Can Self Rally" IsChecked="{Binding CanSelfRally}" Margin="0,5"/>

                            <Button Content="Save MMC Counter" Command="{Binding SaveCommand}" CommandParameter="MMC" Margin="0,20,0,0" Padding="20,10" HorizontalAlignment="Right" Background="CornflowerBlue" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
