<UserControl x:Class="ASLInputTool.Views.AslBoardsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="100">
    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="20" Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
 
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,20">
            <TextBlock Text="Boards" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Add Board" Command="{Binding AddCommand}" 
                    Visibility="{Binding IsAdding, Converter={StaticResource InverseBoolToVis}}"
                    Margin="20,0,0,0" Padding="15,5" Background="{StaticResource ControlBorderBrush}" Foreground="White" FontWeight="Bold"/>
            <Button Content="Delete Selected" Command="{Binding DeleteSelectedCommand}"
                    Visibility="{Binding HasSelectedItems, Converter={StaticResource BoolToVis}}"
                    Margin="10,0,0,0" Padding="15,5" Background="{StaticResource ValidationErrorBrush}" Foreground="White" FontWeight="Bold"/>
            <Button Content="Back to List" Command="{Binding CancelCommand}" 
                    Visibility="{Binding IsAdding, Converter={StaticResource BoolToVis}}"
                    Margin="20,0,0,0" Padding="15,5"/>
        </StackPanel>
 
        <!-- List View -->
        <Grid Grid.Row="1" Visibility="{Binding IsAdding, Converter={StaticResource InverseBoolToVis}}">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="False" Background="{StaticResource WindowBackgroundBrush}">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" 
                                  Command="{Binding EditCommand}" 
                                  CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="30" IsReadOnly="False" CanUserSort="False" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Item.Name}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Type" Binding="{Binding Item.Type}" Width="200" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
 
        <!-- Form View -->
        <Grid Grid.Row="1" Visibility="{Binding IsAdding, Converter={StaticResource BoolToVis}}" Background="{StaticResource WindowBackgroundBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Configuration Form -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" MaxHeight="300" Padding="10">
                <StackPanel>
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="1.5*" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <Label Content="Board Name" FontWeight="SemiBold"/>
                            <TextBox Tag="e.g., 1, 4, 62" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"/>
                        </StackPanel>
     
                        <StackPanel Grid.Column="1" Margin="10,0,10,0">
                            <Label Content="Board Type" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding AvailableBoardTypes}" SelectedItem="{Binding Type}" Padding="5"/>
                        </StackPanel>
     
                        <StackPanel Grid.Column="2" Margin="10,0,10,0" Visibility="{Binding IsDimensionsVisible, Converter={StaticResource BoolToVis}}">
                            <Label Content="Width" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}" Tag="Units"/>
                        </StackPanel>
     
                        <StackPanel Grid.Column="3" Margin="10,0,10,0" Visibility="{Binding IsDimensionsVisible, Converter={StaticResource BoolToVis}}">
                            <Label Content="Height" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}" Tag="Units"/>
                        </StackPanel>

                        <StackPanel Grid.Column="4" Margin="10,0,0,0" VerticalAlignment="Center" Visibility="{Binding IsDimensionsVisible, Converter={StaticResource BoolToVis}}">
                            <UniformGrid Columns="2">
                                <CheckBox Content="Shift Col A Down" IsChecked="{Binding IsFirstColShiftedDown}" Margin="0,5" FontWeight="SemiBold"/>
                                <CheckBox Content="Top: Half" IsChecked="{Binding IsTopRowHalf}" Margin="0,5" FontWeight="SemiBold"/>
                                <CheckBox Content="Left: Half" IsChecked="{Binding IsLeftEdgeHalf}" Margin="0,5" FontWeight="SemiBold"/>
                                <CheckBox Content="Bottom: Half" IsChecked="{Binding IsBottomRowHalf}" Margin="0,5" FontWeight="SemiBold"/>
                                <CheckBox Content="Right: Half" IsChecked="{Binding IsRightEdgeHalf}" Margin="0,5" FontWeight="SemiBold"/>
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
     
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <Label Content="Canvas Width" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding CanvasWidth, UpdateSourceTrigger=PropertyChanged}" Tag="Pixels" IsEnabled="{Binding IsCanvasDimensionsEditable}"/>
                        </StackPanel>
     
                        <StackPanel Grid.Column="1" Margin="10,0,10,0">
                            <Label Content="Canvas Height" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding CanvasHeight, UpdateSourceTrigger=PropertyChanged}" Tag="Pixels" IsEnabled="{Binding IsCanvasDimensionsEditable}"/>
                        </StackPanel>

                        <Grid Grid.Column="2" Margin="10,25,10,0" VerticalAlignment="Top" Height="38">
                            <Button Content="📁" Command="{Binding PickImageCommand}" Width="40" ToolTip="Pick Background Image" 
                                    Visibility="{Binding IsImageDimensionLocked, Converter={StaticResource InverseBoolToVis}}" FontSize="18"/>
                            <Border Background="{StaticResource ControlBorderBrush}" CornerRadius="3" Padding="10,0,5,0"
                                    Visibility="{Binding IsImageDimensionLocked, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding ImageFileName}" VerticalAlignment="Center" Margin="0,0,10,0" FontWeight="SemiBold" Foreground="Black"/>
                                    <Button Content="✕" Command="{Binding ClearImageCommand}" Width="25" Height="25" ToolTip="Clear Image" Foreground="DarkRed" FontWeight="Bold" BorderThickness="0" Background="Transparent"/>
                                </StackPanel>
                            </Border>
                        </Grid>
     
                        <Button Grid.Column="3" Content="Generate" Command="{Binding GenerateCommand}" 
                                Margin="10,25,10,0" Padding="20,10" VerticalAlignment="Top"/>
                                
                        <Button Grid.Column="4" Content="Save Board" Command="{Binding SaveCommand}" 
                                Margin="10,25,0,0" Padding="20,10" Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold" VerticalAlignment="Top"/>
                    </Grid>
                    
                    <Separator Margin="0,10" Background="{StaticResource ControlBorderBrush}" Height="2"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Board Editor Canvas View -->
            <ContentControl Grid.Row="1" Content="{Binding Editor}" />
        </Grid>

        <!-- Toast Notification -->
        <Border Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,40"
                Background="#CC333333" CornerRadius="10" Padding="20,10"
                Visibility="{Binding IsToastVisible, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ToastMessage}" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</UserControl>
