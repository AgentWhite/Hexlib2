<UserControl x:Class="ASLInputTool.Views.SquadsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:ASLInputTool.ViewModels"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance vm:SquadsViewModel}"
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource ControlBorderBrush}"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="20" Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,20">
            <TextBlock Text="Squads &amp; Half-Squads" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Add Squad" Command="{Binding AddCommand}" 
                    Visibility="{Binding IsAdding, Converter={StaticResource InverseBoolToVis}}"
                    Margin="20,0,0,0" Padding="15,5" Background="{StaticResource ControlBorderBrush}" Foreground="White" FontWeight="Bold"/>
            <Button Content="Delete Selected" Command="{Binding DeleteSelectedCommand}"
                    Visibility="{Binding HasSelectedItems, Converter={StaticResource BoolToVis}}"
                    Margin="10,0,0,0" Padding="15,5" Background="{StaticResource ValidationErrorBrush}" Foreground="White" FontWeight="Bold"/>
            <Button Content="Back to List" Command="{Binding CancelCommand}" 
                    Visibility="{Binding IsAdding, Converter={StaticResource BoolToVis}}"
                    Margin="20,0,0,0" Padding="15,5"/>
        </StackPanel>

        <!-- List View -->
        <Grid Grid.Row="1" Visibility="{Binding IsAdding, Converter={StaticResource InverseBoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filter UI -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <Label Content="Filter by Nationality:" VerticalAlignment="Center" Foreground="Gray"/>
                <ComboBox ItemsSource="{Binding Nationalities}" 
                          SelectedItem="{Binding SelectedNationalityFilter}"
                          Width="120" Margin="5,0,0,0"
                          VerticalAlignment="Center"/>
                <Button Content="Clear" Command="{Binding ClearFilterCommand}" 
                        Margin="5,0,0,0" Padding="10,2"
                        Visibility="{Binding SelectedNationalityFilter, Converter={StaticResource NullToVis}, ConverterParameter=Inverse}"/>
            </StackPanel>

            <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredItems}" AutoGenerateColumns="False" IsReadOnly="False" Background="{StaticResource WindowBackgroundBrush}">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" 
                                  Command="{Binding EditCommand}" 
                                  CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="30" IsReadOnly="False" CanUserSort="False" />
                    <DataGridTemplateColumn Header="Image" Width="70" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding Item.ImagePathFront, Converter={StaticResource ImageSource}}" Height="54" Stretch="Uniform"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Name" Binding="{Binding Item.Name}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Nationality" Binding="{Binding Item.Nationality}" Width="120" IsReadOnly="True" />
                    <DataGridTextColumn Header="Class" Binding="{Binding Item.Infantry.AslClass}" Width="100" IsReadOnly="True" />
                    <DataGridTextColumn Header="Squad Size" Binding="{Binding Item.Infantry.Scale}" Width="100" IsReadOnly="True" />
                    <DataGridTextColumn Header="Stats" Binding="{Binding Item, Converter={StaticResource CounterStats}}" Width="100" IsReadOnly="True" SortMemberPath="Item.FirePower.Firepower" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Form View -->
        <ScrollViewer Grid.Row="1" Padding="10" Visibility="{Binding IsAdding, Converter={StaticResource BoolToVis}}" Background="{StaticResource WindowBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Image Frames -->
                <StackPanel Grid.Column="0" Margin="0,0,20,0">
                    <Label Content="Front" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <Button Command="{Binding PickFrontImageCommand}" 
                            Width="120" Height="120" Margin="0,0,0,20">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="2" Background="White">
                                    <Grid>
                                        <Image Source="{Binding ImagePathFront, Converter={StaticResource ImageSource}}" Stretch="UniformToFill"/>
                                        <TextBlock Text="Click for Front" Visibility="{Binding ImagePathFront, Converter={StaticResource NullToVis}}" 
                                                   VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" 
                                                   Foreground="Gray" TextWrapping="Wrap" Padding="10"/>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Label Content="Back" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <Button Command="{Binding PickBackImageCommand}" 
                            Width="120" Height="120">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="2" Background="White">
                                    <Grid>
                                        <Image Source="{Binding ImagePathBack, Converter={StaticResource ImageSource}}" Stretch="UniformToFill"/>
                                        <TextBlock Text="Click for Back" Visibility="{Binding ImagePathBack, Converter={StaticResource NullToVis}}" 
                                                   VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" 
                                                   Foreground="Gray" TextWrapping="Wrap" Padding="10"/>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <Label Content="Unit Identity / Name" FontWeight="SemiBold"/>
                    <TextBox Margin="0,0,0,10" Tag="e.g., 1st Squad" Text="{Binding Name, ValidatesOnNotifyDataErrors=True}" LostFocus="OnTextBoxLostFocus"/>

                    <Label Content="Squad Size" FontWeight="SemiBold"/>
                    <ComboBox Margin="0,0,0,10" Padding="5" ItemsSource="{Binding Scales}" SelectedItem="{Binding SelectedScale}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <Label Content="Nationality" FontWeight="SemiBold"/>
                            <ComboBox Padding="5" ItemsSource="{Binding Nationalities}" SelectedItem="{Binding SelectedNationality}"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <Label Content="Class" FontWeight="SemiBold"/>
                            <ComboBox Padding="5" ItemsSource="{Binding UnitClasses}" SelectedItem="{Binding SelectedClass}"/>
                        </StackPanel>
                    </Grid>

                    <Grid Margin="0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <Label Content="Firepower" FontWeight="SemiBold"/>
                            <TextBox Width="50" HorizontalAlignment="Left" Tag="4" Text="{Binding Firepower, ValidatesOnNotifyDataErrors=True}" LostFocus="OnTextBoxLostFocus"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Margin="0,0,20,0">
                            <Label Content="Range" FontWeight="SemiBold"/>
                            <TextBox Width="50" HorizontalAlignment="Left" Tag="6" Text="{Binding Range, ValidatesOnNotifyDataErrors=True}" LostFocus="OnTextBoxLostFocus"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <Label Content="Morale" FontWeight="SemiBold"/>
                            <TextBox Width="50" HorizontalAlignment="Left" Tag="7" Text="{Binding Morale, ValidatesOnNotifyDataErrors=True}" LostFocus="OnTextBoxLostFocus"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,10">
                        <CheckBox Content="Assault Fire" IsChecked="{Binding HasAssaultFire}" IsEnabled="{Binding CanHaveAssaultFire}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <CheckBox Content="Spraying Fire" IsChecked="{Binding HasSprayingFire}" IsEnabled="{Binding CanHaveSprayingFire}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <CheckBox Content="Self Rally" IsChecked="{Binding CanSelfRally}" IsEnabled="{Binding CanHaveSelfRally}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <CheckBox Content="ELR" IsChecked="{Binding HasELR}" IsEnabled="{Binding CanHaveELR}" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <CheckBox Content="Smoke Exponent" IsChecked="{Binding HasSmokeExponent}" IsEnabled="{Binding CanHaveSmoke}" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox Width="50" VerticalAlignment="Center"
                                 IsEnabled="{Binding HasSmokeExponent}" 
                                 Text="{Binding SmokePlacementExponent}" 
                                 LostFocus="OnTextBoxLostFocus" />
                    </StackPanel>

                    <Separator Margin="0,15,0,10" Background="{StaticResource ControlBorderBrush}"/>
                    <Label Content="Back Side Data" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <Label Content="Broken Morale" FontWeight="SemiBold"/>
                            <TextBox Width="50" HorizontalAlignment="Left" Tag="10" Text="{Binding BrokenMorale, ValidatesOnNotifyDataErrors=True}" LostFocus="OnTextBoxLostFocus"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <Label Content="BPV" FontWeight="SemiBold"/>
                            <TextBox Width="50" HorizontalAlignment="Left" Tag="30" Text="{Binding BPV, ValidatesOnNotifyDataErrors=True}" LostFocus="OnTextBoxLostFocus"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="Save Squad" Command="{Binding SaveCommand}" Margin="0,20,0,0" Padding="20,10" HorizontalAlignment="Right" Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
