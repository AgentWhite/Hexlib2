<UserControl x:Class="ASLInputTool.Views.LeadersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:ASLInputTool.ViewModels"
             xmlns:controls="clr-namespace:ASLInputTool.Controls"
             mc:Ignorable="d" 
             d:DataContext="{d:DesignInstance vm:LeadersViewModel}"
             d:DesignHeight="600" d:DesignWidth="800">
    
    <Grid Margin="20" Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <controls:UnitHeaderControl Grid.Row="0" Title="Leaders" AddButtonText="Add Leader" />

        <!-- List View -->
        <Grid Grid.Row="1" Visibility="{Binding IsAdding, Converter={StaticResource InverseBoolToVis}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filter UI -->
            <controls:UnitFilterControl Grid.Row="0" Margin="0,0,0,10"/>

            <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredItems}" Style="{StaticResource UnitDataGridStyle}" IsReadOnly="False">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" 
                                  Command="{Binding EditCommand}" 
                                  CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="30" IsReadOnly="False" CanUserSort="False" />
                    <DataGridTemplateColumn Header="Image" Width="70" CanUserSort="False">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Image Source="{Binding Item.Visual.ImagePathFront, Converter={StaticResource ImageSource}}" Height="54" Stretch="Uniform"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Name" Binding="{Binding Item.Name}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Module" Binding="{Binding Item.Module}" Width="100" IsReadOnly="True" />
                    <DataGridTextColumn Header="Nationality" Binding="{Binding Item.Nationality}" Width="120" IsReadOnly="True" />
                    <DataGridTextColumn Header="Stats" Binding="{Binding Item, Converter={StaticResource CounterStats}}" Width="100" IsReadOnly="True" SortMemberPath="Item.Leadership.Leadership" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Form View -->
        <ScrollViewer Grid.Row="1" Padding="10" Visibility="{Binding IsAdding, Converter={StaticResource BoolToVis}}" Background="{StaticResource WindowBackgroundBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="270"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Image Frames -->
                <controls:UnitImagePickerControl Grid.Column="0" />

                <StackPanel Grid.Column="1">
                    <Label Content="Unit Identity / Name" FontWeight="SemiBold"/>
                    <TextBox Margin="0,0,0,10" Tag="e.g., Sgt. Steiner" Text="{Binding Name, ValidatesOnNotifyDataErrors=True}" LostFocus="OnTextBoxLostFocus"/>

                    <Label Content="Unit Code (Testing Only)" FontWeight="SemiBold" Foreground="#CC0000"/>
                    <TextBox Margin="0,0,0,10" Tag="e.g., A" Text="{Binding UnitCode}" LostFocus="OnTextBoxLostFocus" BorderBrush="#CC0000" Background="#FFF8F8"/>

                    <Label Content="Nationality" FontWeight="SemiBold"/>
                    <ComboBox Margin="0,0,0,10" Padding="5"
                              ItemsSource="{Binding Nationalities}"
                              SelectedItem="{Binding SelectedNationality}"/>

                    <Label Content="Module" FontWeight="SemiBold"/>
                    <ComboBox Margin="0,0,0,10" Padding="5" 
                              ItemsSource="{Binding AvailableModules}" 
                              SelectedValue="{Binding SelectedModule}" 
                              SelectedValuePath="Module" 
                              DisplayMemberPath="FullName" />

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <Label Content="Morale" FontWeight="SemiBold"/>
                            <TextBox Width="50" HorizontalAlignment="Left" Tag="9" Text="{Binding Morale, ValidatesOnNotifyDataErrors=True}" LostFocus="OnTextBoxLostFocus"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <Label Content="Leadership" FontWeight="SemiBold"/>
                            <TextBox Width="50" HorizontalAlignment="Left" Tag="0" Text="{Binding Leadership, ValidatesOnNotifyDataErrors=True}" LostFocus="OnTextBoxLostFocus"/>
                        </StackPanel>
                    </Grid>
                    
                    <Separator Margin="0,15,0,10" Background="{StaticResource ControlBorderBrush}"/>
                    <Label Content="Back Side Data" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,20,0">
                            <Label Content="Broken Morale" FontWeight="SemiBold"/>
                            <TextBox Width="50" HorizontalAlignment="Left" Tag="10" 
                                     Text="{Binding BrokenMorale, ValidatesOnNotifyDataErrors=True}" 
                                     IsEnabled="{Binding IsBrokenMoraleEnabled}"
                                     LostFocus="OnTextBoxLostFocus"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="Save Leader" Command="{Binding SaveCommand}" Margin="0,20,0,0" Padding="20,10" HorizontalAlignment="Right" Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
