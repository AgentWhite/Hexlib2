<Window x:Class="ASLInputTool.Views.InsigniaSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Select Insignia" Width="420"
        SizeToContent="Height" MinHeight="300" MaxHeight="800"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{StaticResource WindowBackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Select Insignia" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

        <StackPanel Grid.Row="1">
            <Label Content="Available Insignias" FontWeight="SemiBold"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox ItemsSource="{Binding AvailableInsignias}" 
                          SelectedItem="{Binding SelectedInsignia}" 
                          DisplayMemberPath="Name" VerticalContentAlignment="Center" Padding="5"/>
                <Button Grid.Column="1" Content="New" Command="{Binding ToggleNewCommand}" Margin="10,0,0,0" Padding="15,5"/>
            </Grid>

            <!-- New Insignia Section -->
            <Border Visibility="{Binding IsCreatingNew, Converter={StaticResource BoolToVis}}" 
                    BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="1" Padding="15" CornerRadius="5">
                <StackPanel>
                    <Label Content="New Insignia Name" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding NewInsigniaName, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>

                    <Label Content="Insignia Image" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                    <Button Command="{Binding PickImageCommand}" Width="80" Height="200" Margin="0,0,0,20">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="2" Background="White">
                                    <Grid>
                                        <Image Source="{Binding NewInsigniaImagePath, Converter={StaticResource ImageSource}}" Stretch="Uniform"/>
                                        <TextBlock Text="Click to Pick" Visibility="{Binding NewInsigniaImagePath, Converter={StaticResource NullToVis}}" 
                                                   VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="Gray" TextAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    
                    <Button Content="Save" Command="{Binding SaveCommand}" HorizontalAlignment="Right" Padding="25,8" 
                            Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="OK" Command="{Binding OkCommand}" Width="80" Padding="8" Margin="0,0,10,0"/>
            <Button Content="Cancel" Command="{Binding CancelCommand}" Width="80" Padding="8"/>
        </StackPanel>
    </Grid>
</Window>
