<UserControl x:Class="ASLInputTool.Views.ScenariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Background" Value="{StaticResource WindowBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource ControlBorderBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{StaticResource ControlBorderBrush}"/>
        </Style>
    </UserControl.Resources>
    
    <Grid Margin="20" Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,20">
            <TextBlock Text="Scenarios" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Add Scenario" Command="{Binding AddCommand}" 
                    Visibility="{Binding IsAdding, Converter={StaticResource InverseBoolToVis}}"
                    Margin="20,0,0,0" Padding="15,5" Background="{StaticResource ControlBorderBrush}" Foreground="White" FontWeight="Bold"/>
            <Button Content="Delete Selected" Command="{Binding DeleteSelectedCommand}"
                    Visibility="{Binding HasSelectedItems, Converter={StaticResource BoolToVis}}"
                    Margin="10,0,0,0" Padding="15,5" Background="{StaticResource ValidationErrorBrush}" Foreground="White" FontWeight="Bold"/>
            <Button Content="Back to List" Command="{Binding CancelCommand}" 
                    Visibility="{Binding IsAdding, Converter={StaticResource BoolToVis}}"
                    Margin="20,0,0,0" Padding="15,5"/>
        </StackPanel>

        <!-- List View -->
        <Grid Grid.Row="1" Visibility="{Binding IsAdding, Converter={StaticResource InverseBoolToVis}}">
            <DataGrid ItemsSource="{Binding Items}" AutoGenerateColumns="False" IsReadOnly="False" Background="{StaticResource WindowBackgroundBrush}">
                <DataGrid.InputBindings>
                    <MouseBinding MouseAction="LeftDoubleClick" 
                                  Command="{Binding EditCommand}" 
                                  CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                </DataGrid.InputBindings>
                <DataGrid.Columns>
                    <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="30" IsReadOnly="False" />
                    <DataGridTextColumn Header="Name" Binding="{Binding Item.Name}" Width="*" IsReadOnly="True" />
                    <DataGridTextColumn Header="Reference" Binding="{Binding Item.Reference}" Width="150" IsReadOnly="True" />
                    <DataGridTextColumn Header="Attacker" Binding="{Binding Item.AttackerSide.Nationality}" Width="100" IsReadOnly="True" />
                    <DataGridTextColumn Header="Defender" Binding="{Binding Item.DefenderSide.Nationality}" Width="100" IsReadOnly="True" />
                    <DataGridTextColumn Header="Place" Binding="{Binding Item.Description.Place}" Width="150" IsReadOnly="True" />
                    <DataGridTextColumn Header="Date" Binding="{Binding Item.Description.Date}" Width="100" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Form View -->
        <ScrollViewer Grid.Row="1" Padding="10" Visibility="{Binding IsAdding, Converter={StaticResource BoolToVis}}" Background="{StaticResource WindowBackgroundBrush}">
            <StackPanel>
                <!-- Image Frame (Landscape 1.35:1) -->
                <Button Command="{Binding PickImageCommand}" 
                        Width="270" Height="200" Margin="0,0,0,20" HorizontalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="2" Background="White">
                                <Grid>
                                    <Image Source="{Binding ImagePath, Converter={StaticResource ImageSource}}" Stretch="UniformToFill"/>
                                    <TextBlock Text="Click to add scenario image" Visibility="{Binding ImagePath, Converter={StaticResource NullToVis}}" 
                                               VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center" 
                                               Foreground="Gray" TextWrapping="Wrap" Padding="10"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Label Content="Scenario Name" FontWeight="SemiBold"/>
                <TextBox Margin="0,0,0,10" Tag="e.g., FIGHTING WITHDRAWAL" Text="{Binding Name, ValidatesOnNotifyDataErrors=True}" LostFocus="OnTextBoxLostFocus"/>

                <Label Content="Reference (e.g., ASL SCENARIO 1)" FontWeight="SemiBold"/>
                <TextBox Margin="0,0,0,10" Tag="e.g., ASL SCENARIO 1" Text="{Binding Reference, ValidatesOnNotifyDataErrors=True}" LostFocus="OnTextBoxLostFocus"/>

                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <Label Content="Turns" FontWeight="SemiBold"/>
                        <TextBox Width="50" HorizontalAlignment="Left" Text="{Binding Turns, ValidatesOnNotifyDataErrors=True}" LostFocus="OnTextBoxLostFocus"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" VerticalAlignment="Bottom">
                        <CheckBox Content="Has Half Turn" IsChecked="{Binding HasHalfTurn}" Margin="0,0,0,5"/>
                    </StackPanel>
                </Grid>

                <Separator Margin="0,10"/>
                <TextBlock Text="Scenario Sides" FontSize="18" FontWeight="Bold" Margin="0,10"/>
                
                <!-- Side A -->
                <GroupBox Header="Side A" Margin="0,0,0,15" Padding="10" BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <Label Content="Name" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding SideAName, ValidatesOnNotifyDataErrors=True}" Margin="0,0,0,10" Tag="e.g., Finnish Forces" LostFocus="OnTextBoxLostFocus"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="Role" FontWeight="SemiBold"/>
                                <ComboBox ItemsSource="{Binding AvailableSides}" SelectedItem="{Binding SideASide}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="Nationality" FontWeight="SemiBold"/>
                                <ComboBox ItemsSource="{Binding AvailableNationalities}" SelectedItem="{Binding SideANationality}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <!-- Side B -->
                <GroupBox Header="Side B" Margin="0,0,0,10" Padding="10" BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <Label Content="Name" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding SideBName, ValidatesOnNotifyDataErrors=True}" Margin="0,0,0,10" Tag="e.g., Soviet Defenders" LostFocus="OnTextBoxLostFocus"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="20" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <Label Content="Role" FontWeight="SemiBold"/>
                                <ComboBox ItemsSource="{Binding AvailableSides}" SelectedItem="{Binding SideBSide}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Label Content="Nationality" FontWeight="SemiBold"/>
                                <ComboBox ItemsSource="{Binding AvailableNationalities}" SelectedItem="{Binding SideBNationality}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </GroupBox>

                <Separator Margin="0,10"/>
                <TextBlock Text="Historical Context" FontSize="18" FontWeight="Bold" Margin="0,10"/>

                <Label Content="Place" FontWeight="SemiBold"/>
                <TextBox Margin="0,0,0,10" Tag="e.g., SESTRORETSK ROAD, TERIJOKI" Text="{Binding Place, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Date (Text)" FontWeight="SemiBold"/>
                <TextBox Margin="0,0,0,10" Tag="e.g., September 2nd, 1941" Text="{Binding Date, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Historical Description" FontWeight="SemiBold"/>
                <TextBox Margin="0,0,0,10" Height="150" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" 
                         Tag="e.g., The Finns, seeking restitution for the Winter War of 1939..."
                         Text="{Binding DescriptionText, UpdateSourceTrigger=PropertyChanged}"/>

                <Label Content="Aftermath" FontWeight="SemiBold"/>
                <TextBox Margin="0,0,0,20" Height="150" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" 
                         Tag="e.g., The Finnish forces successfully outflanked the Soviet defenders..."
                         Text="{Binding Aftermath, UpdateSourceTrigger=PropertyChanged}"/>

                <Button Content="Save Scenario" Command="{Binding SaveCommand}" HorizontalAlignment="Right" Padding="20,10" Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Toast Notification -->
        <Border Grid.Row="1" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,40"
                Background="#CC333333" CornerRadius="10" Padding="20,10"
                Visibility="{Binding IsToastVisible, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="{Binding ToastMessage}" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
        </Border>
    </Grid>
</UserControl>
