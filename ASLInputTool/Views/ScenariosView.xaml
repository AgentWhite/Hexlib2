<UserControl x:Class="ASLInputTool.Views.ScenariosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch" Margin="0,0,0,20">
            <TextBlock Text="Scenarios" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Add Scenario" Command="{Binding AddScenarioCommand}" 
                    Visibility="{Binding IsAddingScenario, Converter={StaticResource InverseBoolToVis}}"
                    Margin="20,0,0,0" Padding="15,5" Background="CornflowerBlue" Foreground="White" FontWeight="Bold"/>
            <Button Content="Back to List" Command="{Binding CancelAddCommand}" 
                    Visibility="{Binding IsAddingScenario, Converter={StaticResource BoolToVis}}"
                    Margin="20,0,0,0" Padding="15,5"/>
        </StackPanel>

        <!-- List View -->
        <Grid Grid.Row="1" Visibility="{Binding IsAddingScenario, Converter={StaticResource InverseBoolToVis}}">
            <DataGrid ItemsSource="{Binding Scenarios}" AutoGenerateColumns="False" IsReadOnly="True" Background="White">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
                    <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="150" />
                    <DataGridTextColumn Header="Place" Binding="{Binding Description.Place}" Width="150" />
                    <DataGridTextColumn Header="Date" Binding="{Binding Description.Date}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Form View -->
        <ScrollViewer Grid.Row="1" Padding="10" Visibility="{Binding IsAddingScenario, Converter={StaticResource BoolToVis}}">
            <StackPanel>
                <Label Content="Scenario Name:" FontWeight="SemiBold"/>
                <TextBox Margin="0,0,0,10" Padding="5"/>

                <Label Content="Reference (e.g., ASL SCENARIO 1):" FontWeight="SemiBold"/>
                <TextBox Margin="0,0,0,10" Padding="5"/>

                <Separator Margin="0,10"/>
                <TextBlock Text="Historical Context" FontSize="18" FontWeight="Bold" Margin="0,10"/>

                <Label Content="Place:" FontWeight="SemiBold"/>
                <TextBox Margin="0,0,0,10" Padding="5"/>

                <Label Content="Date (Text):" FontWeight="SemiBold"/>
                <TextBox Margin="0,0,0,10" Padding="5"/>

                <Label Content="Historical Description:" FontWeight="SemiBold"/>
                <TextBox Margin="0,0,0,20" Padding="5" Height="150" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

                <Button Content="Save Scenario" HorizontalAlignment="Right" Padding="20,10" Background="Green" Foreground="White" FontWeight="Bold"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
