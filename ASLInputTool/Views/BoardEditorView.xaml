<UserControl x:Class="ASLInputTool.Views.BoardEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:c="clr-namespace:ASLInputTool.Converters"
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             xmlns:vms="clr-namespace:ASLInputTool.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1100">
    <UserControl.Resources>
        <c:EnumToBooleanConverter x:Key="EnumToBooleanConverter" />
        <c:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <c:CenterOffsetConverter x:Key="CenterOffsetConverter" />
        <c:TerrainColorConverter x:Key="TerrainColorConverter" />
        <c:ElevationColorConverter x:Key="ElevationColorConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>
    <Grid Background="{StaticResource WindowBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="250" />
        </Grid.ColumnDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{StaticResource ControlBorderBrush}" Padding="10">
            <StackPanel Orientation="Horizontal">
                <RadioButton Content="Zoom In" IsChecked="{Binding CurrentTool, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=ZoomIn}" 
                             Style="{StaticResource {x:Type ToggleButton}}" Padding="10,5" Margin="0,0,5,0"/>
                <RadioButton Content="Zoom Out" IsChecked="{Binding CurrentTool, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=ZoomOut}" 
                             Style="{StaticResource {x:Type ToggleButton}}" Padding="10,5" Margin="0,0,5,0"/>
                <Button Content="Reset Zoom" Command="{Binding ResetZoomCommand}" Margin="0,0,5,0" Padding="10,5"/>
                <TextBlock Text="{Binding ZoomLevel, StringFormat={}{0:P0}}" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="Gray" FontWeight="Bold"/>
                <Separator Margin="10,0"/>
                <RadioButton Content="Select" IsChecked="{Binding CurrentTool, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Select}" 
                             Style="{StaticResource {x:Type ToggleButton}}" Padding="10,5" Margin="0,0,5,0"/>
                <RadioButton Content="Paint" IsChecked="{Binding CurrentTool, Converter={StaticResource EnumToBooleanConverter}, ConverterParameter=Paint}" 
                             Style="{StaticResource {x:Type ToggleButton}}" Padding="10,5" Margin="0,0,10,0"/>
                <Separator Margin="10,0"/>
                <Button Content="💾 Save Board" Command="{Binding SaveCommand}" 
                        Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="Bold" Padding="15,5"/>
            </StackPanel>
        </Border>

        <!-- Canvas Area -->
        <ScrollViewer x:Name="BoardScrollViewer" Grid.Row="1" Grid.Column="0" Background="{StaticResource WindowBackgroundBrush}" 
                       HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                       PreviewMouseWheel="OnBoardMouseWheel"
                       PreviewMouseDown="OnBoardMouseDown">
            <Grid x:Name="ZoomContainer" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="50">
                <Grid.LayoutTransform>
                    <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}" />
                </Grid.LayoutTransform>
                <Border CornerRadius="2">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="15" Direction="-45" RenderingBias="Quality" ShadowDepth="5" Opacity="0.3"/>
                    </Border.Effect>
                    <Grid Width="{Binding ActualGridWidth}" Height="{Binding ActualGridHeight}">
                        <!-- The Canvas for SVG and Bitmap graphics -->
                        <ItemsControl ItemsSource="{Binding Hexes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas x:Name="EditorCanvas" Width="{Binding ActualGridWidth}" Height="{Binding ActualGridHeight}" Background="White" ClipToBounds="True">
                                    </Canvas>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Panel.ZIndex" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Canvas>
                                        <!-- Base Layer (Full Hex) -->
                                        <!-- Shows Elevation frame if elevated, or Terrain color if at level 0 -->
                                        <Path Data="{Binding Points}">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Setter Property="Stroke" Value="Black"/>
                                                    <Setter Property="StrokeThickness" Value="1"/>
                                                    <Setter Property="Fill" Value="{Binding Elevation, Converter={StaticResource ElevationColorConverter}}"/>
                                                    <Style.Triggers>
                                                        <!-- If not elevated, show Terrain color -->
                                                        <DataTrigger Binding="{Binding IsElevated}" Value="False">
                                                            <Setter Property="Fill" Value="{Binding Terrain, Converter={StaticResource TerrainColorConverter}}"/>
                                                        </DataTrigger>
                                                        <!-- Selection Border -->
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Stroke" Value="#FFFF6666"/>
                                                            <Setter Property="StrokeThickness" Value="3"/>
                                                        </DataTrigger>
                                                        <!-- Hover Highlight -->
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Fill" Value="#33FF0000"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                            <Path.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" 
                                                              Command="{Binding DataContext.SelectHexCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                              CommandParameter="{Binding}" />
                                            </Path.InputBindings>
                                            <Path.ToolTip>
                                                <ToolTip>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Id, StringFormat='Hex: {0}'}" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding Terrain, StringFormat='Terrain: {0}'}"/>
                                                        <TextBlock Text="{Binding Elevation, StringFormat='Elevation: {0}'}"/>
                                                    </StackPanel>
                                                </ToolTip>
                                            </Path.ToolTip>
                                            <i:Interaction.Triggers>
                                                <i:EventTrigger EventName="MouseEnter">
                                                    <i:InvokeCommandAction Command="{Binding DataContext.PaintHexCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                                           CommandParameter="{Binding}" />
                                                </i:EventTrigger>
                                            </i:Interaction.Triggers>
                                        </Path>

                                        <!-- Terrain Layer (Inner Hex) -->
                                        <!-- Only visible if elevated, to show terrain inside the elevation frame -->
                                        <Path Data="{Binding InnerPoints}" IsHitTestVisible="False"
                                              Fill="{Binding Terrain, Converter={StaticResource TerrainColorConverter}}">
                                            <Path.Style>
                                                <Style TargetType="Path">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsElevated}" Value="False">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Path.Style>
                                        </Path>

                                        <!-- Integrated Building Square -->
                                        <Rectangle Width="{Binding BuildingSquareSize}" Height="{Binding BuildingSquareSize}"
                                                   Canvas.Left="{Binding BuildingSquareX}" Canvas.Top="{Binding BuildingSquareY}"
                                                   Fill="{Binding BuildingSquareFill}"
                                                   Stroke="Black" StrokeThickness="1"
                                                   Visibility="{Binding BuildingSquareVisibility}"
                                                   IsHitTestVisible="False" />

                                        <!-- Manhole & Stairwell moved to Top Layer -->

                                        <!-- Graveyard Markers (Headstones) -->
                                        <Canvas Width="{Binding HexSize}" Height="{Binding HexSize}" 
                                                Canvas.Left="{Binding CenterX, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=0.5}"
                                                Canvas.Top="{Binding CenterY, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=0.5}"
                                                IsHitTestVisible="False">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsGraveyard}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <Rectangle Width="6" Height="8" Fill="WhiteSmoke" Stroke="Gray" Canvas.Left="5" Canvas.Top="10"/>
                                            <Rectangle Width="6" Height="8" Fill="WhiteSmoke" Stroke="Gray" Canvas.Left="20" Canvas.Top="5"/>
                                            <Rectangle Width="6" Height="8" Fill="WhiteSmoke" Stroke="Gray" Canvas.Left="12" Canvas.Top="20"/>
                                            <Rectangle Width="6" Height="8" Fill="WhiteSmoke" Stroke="Gray" Canvas.Left="26" Canvas.Top="15"/>
                                        </Canvas>

                                        <!-- Crag Markers (Rock Symbols) -->
                                        <Canvas Width="{Binding HexSize}" Height="{Binding HexSize}" 
                                                Canvas.Left="{Binding CenterX, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=0.5}"
                                                Canvas.Top="{Binding CenterY, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=0.5}"
                                                IsHitTestVisible="False">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsCrag}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <!-- Four abstract rocky clusters -->
                                            <Polygon Points="0,0 12,2 8,10 2,8" Fill="DimGray" Stroke="#444" StrokeThickness="0.5" Canvas.Left="-15" Canvas.Top="-15"/>
                                            <Polygon Points="0,4 10,0 14,8 4,12" Fill="DarkGray" Stroke="#444" StrokeThickness="0.5" Canvas.Left="10" Canvas.Top="-10"/>
                                            <Polygon Points="2,2 10,0 12,10 0,8" Fill="DimGray" Stroke="#444" StrokeThickness="0.5" Canvas.Left="-5" Canvas.Top="12"/>
                                            <Polygon Points="0,0 8,0 6,10 0,6" Fill="SlateGray" Stroke="#444" StrokeThickness="0.5" Canvas.Left="15" Canvas.Top="5"/>
                                        </Canvas>

                                        <!-- Shellhole Markers (Craters) -->
                                        <Canvas Width="{Binding HexSize}" Height="{Binding HexSize}" 
                                                Canvas.Left="{Binding CenterX, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=0.5}"
                                                Canvas.Top="{Binding CenterY, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=0.5}"
                                                IsHitTestVisible="False">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasShellholes}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <!-- Three abstract craters -->
                                            <Ellipse Width="12" Height="10" Fill="SaddleBrown" Stroke="#442200" StrokeThickness="1" Canvas.Left="-8" Canvas.Top="-5">
                                                <Ellipse.Clip>
                                                    <EllipseGeometry RadiusX="5" RadiusY="4" Center="6,5"/>
                                                </Ellipse.Clip>
                                            </Ellipse>
                                            <Polygon Points="0,2 6,0 10,4 8,10 2,8" Fill="#8B4513" Stroke="#442200" StrokeThickness="0.5" Canvas.Left="10" Canvas.Top="5"/>
                                            <Polygon Points="2,0 8,2 10,8 4,10 0,6" Fill="#A0522D" Stroke="#442200" StrokeThickness="0.5" Canvas.Left="-15" Canvas.Top="10"/>
                                        </Canvas>

                                        <!-- Pond Marker (Circular Water Body) -->
                                        <Canvas Canvas.Left="{Binding CenterX, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=0.5}"
                                                Canvas.Top="{Binding CenterY, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=0.5}"
                                                IsHitTestVisible="False">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPond}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <Ellipse Width="50" Height="40" Fill="{StaticResource WaterBrush}" Stroke="SteelBlue" StrokeThickness="1"
                                                     Canvas.Left="-25" Canvas.Top="-20"/>
                                        </Canvas>

                                        <!-- Lumberyard Markers (Wood Stacks) -->
                                        <Canvas Width="{Binding HexSize}" Height="{Binding HexSize}" 
                                                Canvas.Left="{Binding CenterX, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=0.5}"
                                                Canvas.Top="{Binding CenterY, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=0.5}"
                                                IsHitTestVisible="False">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsLumberyard}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <!-- Seveal rectangular stacks scattered across the hex -->
                                            <Rectangle Width="14" Height="8" Fill="SaddleBrown" Stroke="#331100" StrokeThickness="0.5" Canvas.Left="-18" Canvas.Top="-12" RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform>
                                                    <RotateTransform Angle="15"/>
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle Width="12" Height="7" Fill="#8B4513" Stroke="#331100" StrokeThickness="0.5" Canvas.Left="4" Canvas.Top="-15" RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform>
                                                    <RotateTransform Angle="-10"/>
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle Width="15" Height="9" Fill="SaddleBrown" Stroke="#331100" StrokeThickness="0.5" Canvas.Left="-5" Canvas.Top="0" RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform>
                                                    <RotateTransform Angle="5"/>
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle Width="10" Height="6" Fill="#A0522D" Stroke="#331100" StrokeThickness="0.5" Canvas.Left="10" Canvas.Top="12" RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform>
                                                    <RotateTransform Angle="45"/>
                                                </Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle Width="12" Height="7" Fill="SaddleBrown" Stroke="#331100" StrokeThickness="0.5" Canvas.Left="-12" Canvas.Top="15"/>
                                        </Canvas>

                                        <!-- Stone Rubble Layer (Blue-grey shard shards) -->
                                        <Canvas Canvas.Left="{Binding CenterX, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=0.5}"
                                                Canvas.Top="{Binding CenterY, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=0.5}"
                                                IsHitTestVisible="False">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsStoneRubble}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <!-- Abstract shards -->
                                            <Polygon Points="0,0 6,2 4,8 0,6" Fill="SteelBlue" Opacity="0.8" Stroke="#223344" StrokeThickness="0.5" Canvas.Left="-15" Canvas.Top="-15"/>
                                            <Polygon Points="0,2 8,0 10,6 2,8" Fill="LightSlateGray" Opacity="0.8" Stroke="#223344" StrokeThickness="0.5" Canvas.Left="5" Canvas.Top="-10"/>
                                            <Polygon Points="2,0 10,2 8,10 0,6" Fill="CadetBlue" Opacity="0.8" Stroke="#223344" StrokeThickness="0.5" Canvas.Left="-8" Canvas.Top="2"/>
                                            <Polygon Points="0,4 6,0 10,8 2,10" Fill="SteelBlue" Opacity="0.8" Stroke="#223344" StrokeThickness="0.5" Canvas.Left="10" Canvas.Top="10"/>
                                            <Polygon Points="0,0 8,4 4,10" Fill="LightSlateGray" Opacity="0.8" Stroke="#223344" StrokeThickness="0.5" Canvas.Left="-22" Canvas.Top="5"/>
                                        </Canvas>

                                        <!-- Wooden Rubble Layer (Brown splinters) -->
                                        <Canvas Canvas.Left="{Binding CenterX, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=0.5}"
                                                Canvas.Top="{Binding CenterY, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=0.5}"
                                                IsHitTestVisible="False">
                                            <Canvas.Style>
                                                <Style TargetType="Canvas">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsWoodenRubble}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Canvas.Style>
                                            <!-- Abstract splinters/planks -->
                                            <Rectangle Width="18" Height="3" Fill="SaddleBrown" Stroke="#331100" StrokeThickness="0.3" Canvas.Left="-20" Canvas.Top="-15" RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform><RotateTransform Angle="25"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle Width="15" Height="2.5" Fill="#8B4513" Stroke="#331100" StrokeThickness="0.3" Canvas.Left="2" Canvas.Top="-18" RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform><RotateTransform Angle="-15"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle Width="20" Height="4" Fill="#A0522D" Stroke="#331100" StrokeThickness="0.3" Canvas.Left="-5" Canvas.Top="0" RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform><RotateTransform Angle="10"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle Width="12" Height="2" Fill="SaddleBrown" Stroke="#331100" StrokeThickness="0.3" Canvas.Left="12" Canvas.Top="12" RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform><RotateTransform Angle="60"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle Width="16" Height="3" Fill="#5C4033" Stroke="#331100" StrokeThickness="0.3" Canvas.Left="-18" Canvas.Top="10" RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform><RotateTransform Angle="-40"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                            <Rectangle Width="10" Height="2" Fill="#8B4513" Stroke="#331100" StrokeThickness="0.3" Canvas.Left="0" Canvas.Top="20" RenderTransformOrigin="0.5,0.5">
                                                <Rectangle.RenderTransform><RotateTransform Angle="5"/></Rectangle.RenderTransform>
                                            </Rectangle>
                                        </Canvas>
                                        
                                        
                                        <!-- Hex Edges for Selection -->
                                        <Line X1="{Binding HexCorners[0].X}" Y1="{Binding HexCorners[0].Y}" X2="{Binding HexCorners[1].X}" Y2="{Binding HexCorners[1].Y}" StrokeThickness="8">
                                            <Line.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding SelectEdgeCommand}" CommandParameter="0"/>
                                            </Line.InputBindings>
                                            <Line.Style>
                                                <Style TargetType="Line">
                                                    <Setter Property="Stroke" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Stroke" Value="Cyan"/></Trigger>
                                                        <DataTrigger Binding="{Binding IsEdge0Selected}" Value="True"><Setter Property="Stroke" Value="Gold"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Line.Style>
                                        </Line>
                                        <Line X1="{Binding HexCorners[1].X}" Y1="{Binding HexCorners[1].Y}" X2="{Binding HexCorners[2].X}" Y2="{Binding HexCorners[2].Y}" StrokeThickness="8">
                                            <Line.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding SelectEdgeCommand}" CommandParameter="1"/>
                                            </Line.InputBindings>
                                            <Line.Style>
                                                <Style TargetType="Line">
                                                    <Setter Property="Stroke" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Stroke" Value="Cyan"/></Trigger>
                                                        <DataTrigger Binding="{Binding IsEdge1Selected}" Value="True"><Setter Property="Stroke" Value="Gold"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Line.Style>
                                        </Line>
                                        <Line X1="{Binding HexCorners[2].X}" Y1="{Binding HexCorners[2].Y}" X2="{Binding HexCorners[3].X}" Y2="{Binding HexCorners[3].Y}" StrokeThickness="8">
                                            <Line.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding SelectEdgeCommand}" CommandParameter="2"/>
                                            </Line.InputBindings>
                                            <Line.Style>
                                                <Style TargetType="Line">
                                                    <Setter Property="Stroke" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Stroke" Value="Cyan"/></Trigger>
                                                        <DataTrigger Binding="{Binding IsEdge2Selected}" Value="True"><Setter Property="Stroke" Value="Gold"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Line.Style>
                                        </Line>
                                        <Line X1="{Binding HexCorners[3].X}" Y1="{Binding HexCorners[3].Y}" X2="{Binding HexCorners[4].X}" Y2="{Binding HexCorners[4].Y}" StrokeThickness="8">
                                            <Line.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding SelectEdgeCommand}" CommandParameter="3"/>
                                            </Line.InputBindings>
                                            <Line.Style>
                                                <Style TargetType="Line">
                                                    <Setter Property="Stroke" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Stroke" Value="Cyan"/></Trigger>
                                                        <DataTrigger Binding="{Binding IsEdge3Selected}" Value="True"><Setter Property="Stroke" Value="Gold"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Line.Style>
                                        </Line>
                                        <Line X1="{Binding HexCorners[4].X}" Y1="{Binding HexCorners[4].Y}" X2="{Binding HexCorners[5].X}" Y2="{Binding HexCorners[5].Y}" StrokeThickness="8">
                                            <Line.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding SelectEdgeCommand}" CommandParameter="4"/>
                                            </Line.InputBindings>
                                            <Line.Style>
                                                <Style TargetType="Line">
                                                    <Setter Property="Stroke" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Stroke" Value="Cyan"/></Trigger>
                                                        <DataTrigger Binding="{Binding IsEdge4Selected}" Value="True"><Setter Property="Stroke" Value="Gold"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Line.Style>
                                        </Line>
                                        <Line X1="{Binding HexCorners[5].X}" Y1="{Binding HexCorners[5].Y}" X2="{Binding HexCorners[0].X}" Y2="{Binding HexCorners[0].Y}" StrokeThickness="8">
                                            <Line.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding SelectEdgeCommand}" CommandParameter="5"/>
                                            </Line.InputBindings>
                                            <Line.Style>
                                                <Style TargetType="Line">
                                                    <Setter Property="Stroke" Value="Transparent"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True"><Setter Property="Stroke" Value="Cyan"/></Trigger>
                                                        <DataTrigger Binding="{Binding IsEdge5Selected}" Value="True"><Setter Property="Stroke" Value="Gold"/></DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Line.Style>
                                        </Line>
                                    </Canvas>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Water Visuals (Streams, Gullies, Canals) -->
                        <ItemsControl ItemsSource="{Binding WaterVisuals}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas IsHitTestVisible="False"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Line X1="{Binding X1}" Y1="{Binding Y1}" 
                                          X2="{Binding X2}" Y2="{Binding Y2}" 
                                          Stroke="{Binding Stroke}" 
                                          StrokeThickness="{Binding Thickness}" 
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Cliff Visuals -->
                        <ItemsControl ItemsSource="{Binding CliffVisuals}" Panel.ZIndex="5" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas IsHitTestVisible="False"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Path Data="{Binding PathData}" Stroke="{Binding Stroke}" StrokeThickness="{Binding Thickness}"
                                          StrokeDashArray="3 1" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Hexside Terrain Layer (Walls, Hedges) -->
                            <ItemsControl ItemsSource="{Binding HexsideTerrainVisuals}" Panel.ZIndex="3" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas IsHitTestVisible="False"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Line X1="{Binding P1.X}" Y1="{Binding P1.Y}" 
                                              X2="{Binding P2.X}" Y2="{Binding P2.Y}" 
                                              Stroke="{Binding Stroke}" 
                                              StrokeThickness="{Binding Thickness}" 
                                              StrokeDashArray="{Binding DashArray}"
                                              StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Road Visuals -->
                        <ItemsControl ItemsSource="{Binding RoadVisuals}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas IsHitTestVisible="False"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Line X1="{Binding X1}" Y1="{Binding Y1}" 
                                          X2="{Binding X2}" Y2="{Binding Y2}" 
                                          Stroke="{Binding Stroke}" 
                                          StrokeThickness="{Binding Thickness}" 
                                          StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Overlay background image -->
                        <Image Source="{Binding BackgroundImage}" Stretch="Fill" Opacity="0.4" IsHitTestVisible="False" />

                        <!-- Building Visuals (Connectors only) -->
                        <ItemsControl ItemsSource="{Binding BuildingVisuals}" Panel.ZIndex="10" 
                                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                            <ItemsControl.Resources>
                                <!-- Rectangle for House Hexside Connectors -->
                                <DataTemplate DataType="{x:Type vms:BuildingConnectorViewModel}">
                                    <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                          X2="{Binding X2}" Y2="{Binding Y2}"
                                          Stroke="{Binding Fill}"
                                          StrokeThickness="{Binding Thickness}"/>
                                </DataTemplate>
                                <!-- Black Divider line for Rowhouses -->
                                <DataTemplate DataType="{x:Type vms:BuildingDividerViewModel}">
                                    <Line X1="{Binding X1}" Y1="{Binding Y1}"
                                          X2="{Binding X2}" Y2="{Binding Y2}"
                                          Stroke="{Binding Fill}"
                                          StrokeThickness="{Binding Thickness}"/>
                                </DataTemplate>
                            </ItemsControl.Resources>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Canvas.Left" Value="{Binding CanvasX}"/>
                                    <Setter Property="Canvas.Top" Value="{Binding CanvasY}"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas IsHitTestVisible="False"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <!-- Top Decoration Layer (Manholes, Stairwells, etc.) -->
                        <!-- Sitting above Building Connectors to ensure visibility -->
                        <ItemsControl ItemsSource="{Binding Hexes}" Panel.ZIndex="20"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas IsHitTestVisible="False"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Canvas>
                                        <!-- Manhole Cover (Black circle) -->
                                        <Ellipse Width="10" Height="10" Fill="Black" 
                                                 Canvas.Left="{Binding CenterX, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=-13}"
                                                 Canvas.Top="{Binding CenterY, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=-5}"
                                                 Visibility="{Binding HasManhole, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                 IsHitTestVisible="False"/>

                                        <!-- Stairwell (White square) -->
                                        <Rectangle Width="10" Height="10" Fill="White" Stroke="Black" StrokeThickness="1"
                                                   Canvas.Left="{Binding CenterX, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=3}"
                                                   Canvas.Top="{Binding CenterY, Converter={StaticResource CenterOffsetConverter}, ConverterParameter=-5}"
                                                   Visibility="{Binding HasStairwell, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                   IsHitTestVisible="False"/>
                                    </Canvas>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Final Label Layer (Coordinates) - Always on Top -->
                        <ItemsControl ItemsSource="{Binding Hexes}" Panel.ZIndex="100"
                                      HorizontalAlignment="Stretch" VerticalAlignment="Stretch" IsHitTestVisible="False">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <Canvas IsHitTestVisible="False"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Canvas IsHitTestVisible="False">
                                        <TextBlock Text="{Binding Id}" 
                                                   Canvas.Left="{Binding LabelLeft}" 
                                                   Canvas.Top="{Binding LabelY}"
                                                   Width="{Binding HexSize}"
                                                   TextAlignment="Center"
                                                   FontSize="10"
                                                   FontWeight="SemiBold"
                                                   Foreground="Black"
                                                   IsHitTestVisible="False" />
                                    </Canvas>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Sidebar / Tools Pane -->
        <Border Grid.Row="1" Grid.Column="1" Background="{StaticResource ControlBorderBrush}" BorderBrush="{StaticResource ControlBorderBrush}" BorderThickness="1,0,0,0" Padding="15">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="Properties" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                    
                    <!-- Tool Options -->
                    <GroupBox Header="Brush Settings" Margin="0,0,0,15">
                        <GroupBox.Style>
                            <Style TargetType="GroupBox">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding CurrentTool}" Value="Paint">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </GroupBox.Style>
                        <StackPanel Margin="5">
                            <TextBlock Text="Active Terrain:"/>
                            <ComboBox ItemsSource="{Binding AvailableTerrainTypes}" SelectedItem="{Binding ActiveTerrain}" Margin="0,5,0,0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Rectangle Width="16" Height="16" Margin="0,0,5,0" Fill="{Binding Converter={StaticResource TerrainColorConverter}, ConverterParameter=Icon}" Stroke="Gray" StrokeThickness="1" />
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </StackPanel>
                    </GroupBox>
    
                    <!-- Selected Hex Info -->
                    <GroupBox Header="Selected Hex" Visibility="{Binding SelectedHex, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                        <StackPanel Margin="5" DataContext="{Binding SelectedHex}">
                            <TextBlock Text="{Binding Id, StringFormat='ID: {0}'}" FontWeight="Bold" Margin="0,0,10,10"/>
                            
                            <TextBlock Text="Terrain:"/>
                            <ComboBox ItemsSource="{Binding DataContext.AvailableTerrainTypes, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                      SelectedItem="{Binding Terrain}" Margin="0,5,0,10">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Rectangle Width="16" Height="16" Margin="0,0,5,0" Fill="{Binding Converter={StaticResource TerrainColorConverter}, ConverterParameter=Icon}" Stroke="Gray" StrokeThickness="1" />
                                            <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
    
                            <TextBlock Text="{Binding Elevation, StringFormat='Elevation: {0}'}"/>
                            <Slider Minimum="0" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding Elevation}" Margin="0,0,0,10"/>
    
                            <CheckBox Content="Manhole" IsChecked="{Binding HasManhole}" Margin="0,5"/>
                            <CheckBox Content="Shellholes" IsChecked="{Binding HasShellholes}" Margin="0,5"/>
                            <CheckBox Content="Stairwell" IsChecked="{Binding HasStairwell}" Visibility="{Binding BuildingSquareVisibility}" Margin="0,5"/>
    
                            <TextBlock Text="Rubble:" Margin="0,5,0,0"/>
                            <ComboBox ItemsSource="{Binding DataContext.AvailableRubbleTypes, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                      SelectedItem="{Binding Rubble}" Margin="0,2,0,5"/>
                        </StackPanel>
                    </GroupBox>
    
                    <!-- Selected Hexside Info -->
                    <GroupBox Header="Selected Hexside" Visibility="{Binding SelectedEdge, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                        <StackPanel Margin="5" DataContext="{Binding SelectedEdge.Data}">
                            <CheckBox Content="Wall" IsChecked="{Binding HasWall}" Margin="0,5"/>
                            <CheckBox Content="Hedge" IsChecked="{Binding HasHedge}" Margin="0,5"/>
                            <CheckBox Content="Bocage" IsChecked="{Binding HasBocage}" Margin="0,5"/>
                            <CheckBox Content="Paved Road" IsChecked="{Binding HasPavedRoad}" Margin="0,5"/>
                            <CheckBox Content="Dirt Road" IsChecked="{Binding HasDirtRoad}" Margin="0,5"/>
                            <CheckBox Content="Path" IsChecked="{Binding HasPath}" Margin="0,5"/>
                            <CheckBox Content="House" IsChecked="{Binding HasHouse}" IsEnabled="{Binding IsHouseConnectionAvailable}" Margin="0,5"/>
                            <CheckBox Content="Rowhouse" IsChecked="{Binding IsRowhouse}" IsEnabled="{Binding IsHouseConnectionAvailable}" Margin="0,5"/>
                            <Separator Margin="0,5"/>
                            <CheckBox Content="Stream" IsChecked="{Binding HasStream}" Margin="0,5"/>
                            <CheckBox Content="Gully" IsChecked="{Binding HasGully}" Margin="0,5"/>
                            <CheckBox Content="Canal" IsChecked="{Binding HasCanal}" Margin="0,5"/>
                            <CheckBox Content="Cliff" IsChecked="{Binding HasCliff}" Margin="0,5"/>
                        </StackPanel>
                    </GroupBox>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
